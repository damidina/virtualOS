# Cloudflare account credentials
# Do NOT commit real values.
CLOUDFLARE_API_TOKEN=replace_me
CLOUDFLARE_ACCOUNT_ID=replace_me

# Cloudflare Access service token pair (for client app headers)
CF_ACCESS_CLIENT_ID=replace_me
CF_ACCESS_CLIENT_SECRET=replace_me

# Origin server auth token (Bearer)
VOS_AUTH_TOKEN=replace_me

# Protected remote URL
REMOTE_URL=https://remote.yourdomain.com
